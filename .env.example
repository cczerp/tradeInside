# Copy this file to .env and fill in real values.
# Never commit the real .env.

# ===== DATABASE =====
DB_HOST=localhost
DB_NAME=insider_trading
DB_USER=postgres
DB_PASSWORD=
DB_PORT=5432

# ===== PROXY/VPN (optional) =====
NORD_USER=
NORD_PASS=

# ===== EMAIL (SMTP) =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASS=
# Comma-separated list of recipients
EMAIL_TO=

# ===== TELEGRAM ALERTS (optional) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== SCRAPER SETTINGS =====
SCRAPE_INTERVAL=24
MAX_ROWS=1000
HEADLESS=true

# ===== ANALYZER SETTINGS =====
CLUSTER_MIN_TRADERS=3
CLUSTER_DAYS_WINDOW=7
MIN_CONFIDENCE_SCORE=70
PRICE_SPIKE_THRESHOLD=10

# ===== API KEYS =====
ALPHA_VANTAGE_KEY=

# ===== LOGGING =====
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=./logs/insider_trading.log

# ===== SAFETY =====
ENABLE_RATE_LIMIT=true
REQUESTS_PER_MINUTE=10
